# MongoDB
MONGO_URI=mongodb://localhost:27017

# Redis (Celery)
REDIS_URL=redis://localhost:6379/0

# LLM / APIs
LLM_API_KEY=your_llm_key
ASTRO_API_KEY=your_astro_key

# Prokerala (daily horoscope)
PROKERALA_CLIENT_ID=your_prokerala_client_id
PROKERALA_CLIENT_SECRET=your_prokerala_client_secret

# MCP server URL (SSE endpoint; run mcp_serv.server before main app)
MCP_SERVER_URL=http://localhost:8001/sse

# Optional: MCP server host/port when running python -m mcp_serv.server
# MCP_HOST=127.0.0.1
# MCP_PORT=8001

# Wasender webhook secret (matches X-Webhook-Signature header)
# WASENDER_WEBHOOK_SECRET=your_webhook_secret

# Wasender outbound send-message API
# WASENDER_API_BASE_URL=https://www.wasenderapi.com
# WASENDER_API_KEY=your_wasender_session_api_key
